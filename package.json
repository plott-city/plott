{
  "name": "plott",
  "version": "0.4.0",
  "description": "Agent orchestration platform - build your agent city",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "keywords": [
    "agents",
    "orchestration",
    "pipelines",
    "monitoring",
    "solana",
    "city"
  ],
  "author": "plott-city",
  "license": "MIT",
  "dependencies": {
    "hono": "^4.3.0",
    "@hono/node-server": "^1.11.0",
    "@hono/zod-validator": "^0.2.0",
    "drizzle-orm": "^0.30.0",
    "postgres": "^3.4.0",
    "ioredis": "^5.3.0",
    "bullmq": "^5.7.0",
    "zod": "^3.23.0",
    "pino": "^9.1.0",
    "pino-pretty": "^11.1.0",
    "nanoid": "^5.0.0",
    "dayjs": "^1.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.10.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.12.0",
    "eslint": "^9.3.0",
    "@eslint/js": "^9.3.0",
    "typescript-eslint": "^8.0.0",
    "drizzle-kit": "^0.21.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}
